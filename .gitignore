# ----------------------------------------
# 0. 기본적으로 모든 파일 무시
/*
.*


# ----------------------------------------
# 1. Git에 포함할 필수 파일/디렉토리 예외 처리

# Dart 소스코드
!lib/
!lib/**

# 테스트 코드 (원하면 유지, 필요 없으면 주석처리 가능)
!test/
!test/**

# 의존성 및 설정
!pubspec.yaml
!pubspec.lock
!analysis_options.yaml

# 환경 설정 파일 (원한다면)
!README.md
!LICENSE
!CHANGELOG.md
!assets/
!assets/**


# ----------------------------------------
# 2. 무시할 일반적인 파일/폴더 (Flutter 공통)

# 빌드 결과
build/
.dart_tool/
.packages
.pub/
.pub-cache/

# iOS / Android / macOS / Windows 등 플랫폼 파일
android/
ios/
macos/
windows/
linux/
web/

# IDE / 에디터 관련
.idea/
.vscode/
*.iml

# 기타 불필요 파일
*.log
*.tmp
*.swp
.DS_Store

# 심볼파일 / 난독화
app.*.symbols
app.*.map.json